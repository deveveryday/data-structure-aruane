   ],
   "source": [
    "my_list = [50, 3, 11000, 1, 2, 0, 5, 10, 11, 13, 12]\n",
    "length = len(my_list)\n",
    "\n",
    "for i in range(length):\n",
    "    for j  in range(length - i - 1):\n",
    "        if my_list[j] > my_list[j + 1]:\n",
    "            my_list[j], my_list[j + 1] = my_list[j + 1], my_list[j]\n",
    "\n",
    "my_list"
   ]
  }
 ],
